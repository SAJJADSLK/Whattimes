# Database: use the pooled Neon URL for normal serverless runtime.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?channel_binding=require&sslmode=require

# Optional: use the unpooled Neon URL for migrations or one-off database jobs.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Vercel/Postgres-compatible aliases. These are optional for this codebase, but useful if
# you connect Vercel integrations or templates that expect POSTGRES_* variable names.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DATABASE?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST_UNPOOLED/DATABASE?sslmode=require
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST/DATABASE?channel_binding=require&connect_timeout=15&sslmode=require
POSTGRES_USER=USER
POSTGRES_HOST=HOST
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DATABASE=DATABASE

# Session & Auth
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters
VITE_APP_ID=your_oauth_app_id
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
OAUTH_SERVER_URL=https://your-oauth-server.example.com
OWNER_OPEN_ID=optional_owner_open_id

# App Config
VITE_APP_TITLE=WhatTime
VITE_APP_LOGO=https://your-logo-url.png

# Optional analytics. Leave blank if you do not use Umami analytics.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional storage proxy variables used only if /manus-storage assets are required.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Node Environment
NODE_ENV=production
