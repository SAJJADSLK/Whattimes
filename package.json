{
  "name": "whattime",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/_core/index.ts",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --outDir dist/public",
    "build:server": "esbuild server/_core/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:express --external:@trpc/server --external:drizzle-orm --external:postgres --alias:@shared=./shared --alias:@=./",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@t3-oss/env-core": "^0.10.1",
    "@tanstack/react-query": "^5.28.0",
    "@trpc/client": "^11.0.0-rc.461",
    "@trpc/react-query": "^11.0.0-rc.461",
    "@trpc/server": "^11.0.0-rc.461",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "drizzle-orm": "^0.30.9",
    "express": "^4.18.2",
    "luxon": "^3.4.1",
    "postgres": "^3.4.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "sonner": "^1.2.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^4.1.14",
    "wouter": "^3.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^24.7.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.10",
    "postcss": "^8.5.6",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4",
    "vite": "^5.4.7"
  }
}
